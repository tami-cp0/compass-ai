# All values are required — the API throws on missing env at startup.

# Server
NODE_ENV=
PORT=
# trace | debug | info | warn | error | fatal. Default to "debug" in dev, "info" in prod.
LOG_LEVEL=
# Optional: stable instance identifier for multi-instance deployments. Falls back to hostname.
INSTANCE_ID=
# Optional: comma-separated session IDs to log at debug level even when LOG_LEVEL=info. For targeted prod debugging.
DEBUG_SESSION_IDS=
# Comma-separated list of allowed WS origins. Use chrome-extension://<id> for the extension in prod.
# Ignored when NODE_ENV=development.
ALLOWED_ORIGINS=

# Redis
REDIS_URL=

# Google (Gemini Live voice session)
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=

# OpenAI (research)
OPENAI_API_KEY=
OPENAI_VECTOR_STORE_ID=
OPENAI_RESEARCH_MODEL=
OPENAI_ALT_RESEARCH_MODEL=

# claude
CLAUDE_API_KEY=
CLAUDE_WEB_MODEL=