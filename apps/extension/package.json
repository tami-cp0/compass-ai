{
  "name": "@compass-ai/extension",
  "displayName": "Compass AI",
  "version": "0.1.0",
  "private": true,
  "description": "A voice copilot for Atlass Portfolios: ask, get answers and let it act on the page for you.",
  "author": "Oluwatamilore Olugbesan <findtamilore@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@compass-ai/types": "workspace:*",
    "lucide-react": "^1.16.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "^8.0.7",
    "remark-gfm": "^3.0.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "prettier": "3.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "tabs",
      "activeTab"
    ],
    "action": {}
  }
}